APP_ENV=development
APP_NAME=Stock Data Sync
APP_VERSION=dev
APP_DEBUG=true
APP_API_PREFIX=/api/v1
APP_CORS_ORIGINS=["http://localhost:5173"]
APP_LOG_FILE=
APP_LOG_MAX_BYTES=52428800
APP_LOG_BACKUP_COUNT=10

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stock_data_sync
POSTGRES_USER=stock_sync
POSTGRES_PASSWORD=stock_sync
DATABASE_URL=postgresql+psycopg://stock_sync:stock_sync@localhost:5432/stock_data_sync
RAW_DATA_DIR=./data/raw
RAW_STORAGE_WARNING_USED_PERCENT=85
RAW_STORAGE_PROTECT_USED_PERCENT=92
RAW_STORAGE_WARNING_FREE_BYTES=21474836480
RAW_STORAGE_PROTECT_FREE_BYTES=10737418240
WEB_DIST_DIR=
ADMIN_API_TOKEN=
BACKUP_TARGET_DIR=

TUSHARE_TOKEN=
TUSHARE_REQUEST_LIMIT_PER_MINUTE=500
TUSHARE_REQUEST_BUDGET_PER_MINUTE=480
TUSHARE_TIMEOUT_SECONDS=30
TUSHARE_MAX_ATTEMPTS=3
TUSHARE_RETRY_WAIT_SECONDS=2

SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_JOBSTORE_TABLE=apscheduler_jobs
SCHEDULER_ADVISORY_LOCK_ID=731500001
PROCESSING_ADVISORY_LOCK_ID=731500002
SCHEDULER_MAX_WORKERS=4
SCHEDULER_POLL_SECONDS=30
PARTITION_MONTHS_AHEAD=3
COLLECTION_MAX_WORKERS=4
COLLECTION_RUNNING_TIMEOUT_SECONDS=1800
PROCESSING_RUNNING_TIMEOUT_SECONDS=21600

VITE_API_BASE_URL=/api/v1
